{
  "name": "bevy_ex_ui_web_doc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "wasm:build:button": "bash scripts/trunk-build.sh wasm/examples/button",
    "wasm:build": "pnpm wasm:build:button",
    "docker:build": "docker build -t bevy-ex-ui-web-doc .",
    "docker:run": "docker run --rm -p 8080:80 bevy-ex-ui-web-doc",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=playwright/browsers playwright test --config=playwright/playwright.config.ts",
    "test:e2e:ui": "PLAYWRIGHT_BROWSERS_PATH=playwright/browsers playwright test --ui --config=playwright/playwright.config.ts",
    "test:e2e:headed": "PLAYWRIGHT_BROWSERS_PATH=playwright/browsers playwright test --headed --config=playwright/playwright.config.ts",
    "test:e2e:report": "playwright show-report playwright/reports/html",
    "test:e2e:install": "PLAYWRIGHT_BROWSERS_PATH=playwright/browsers playwright install chromium"
  },
  "dependencies": {
    "@fluent/bundle": "^0.19.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
